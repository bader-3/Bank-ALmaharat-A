# Gemini API — get key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: force a specific model
# GEMINI_MODEL=gemini-2.0-flash-lite

# Fallback to mock AI when Gemini quota/key fails (default: enabled)
# AI_FALLBACK_ON_ERROR=false

# Alternative env name (optional)
# GOOGLE_GENERATIVE_AI_API_KEY=